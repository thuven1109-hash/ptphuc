rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      let data = request.resource.data;
      return data.keys().hasOnly(['uid', 'apiKey', 'selectedModel', 'userProfiles', 'musicState']) &&
             (data.uid is string && data.uid.size() > 0 && data.uid.size() < 100) &&
             (!('apiKey' in data) || (data.apiKey is string && data.apiKey.size() < 200)) &&
             (!('selectedModel' in data) || (data.selectedModel is string && data.selectedModel.size() < 100)) &&
             (!('userProfiles' in data) || (data.userProfiles is list && data.userProfiles.size() <= 5)) &&
             (!('musicState' in data) || data.musicState is map);
    }

    function isValidChatSession() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'id', 'name', 'messages', 'lastUpdate', 'userInfo']) &&
             (data.uid is string && data.uid.size() > 0 && data.uid.size() < 100) &&
             (data.id is string && data.id.size() > 0 && data.id.size() < 100) &&
             (data.name is string && data.name.size() > 0 && data.name.size() < 100) &&
             (data.messages is list) &&
             (data.lastUpdate is number) &&
             (data.userInfo is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified();
      allow delete: if isOwner(userId);

      match /sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatSession() && uidUnchanged();
        allow update: if isOwner(userId) && isValidChatSession() && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }
  }
}

